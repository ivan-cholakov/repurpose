# Copy to .env and fill in. See README.md "Going live" for where each value comes from.

# Database. SQLite for local dev; use a Postgres URL in production (e.g. Neon, Supabase).
DATABASE_URL="file:./dev.db"

# Long random string used to sign session cookies. Generate with: openssl rand -base64 32
AUTH_SECRET=""

# Claude API key — https://console.anthropic.com  (Settings → API Keys)
ANTHROPIC_API_KEY=""

# Stripe — https://dashboard.stripe.com  (test keys live under /test)
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
STRIPE_PRICE_ID=""        # the recurring Price ID for your Pro plan (price_...)

# Optional: second recurring Price for annual billing (enables the yearly option)
STRIPE_PRICE_ID_ANNUAL=""

# Transactional email via Resend — https://resend.com (enables password reset +
# email verification; without it those flows degrade gracefully in dev)
RESEND_API_KEY=""
EMAIL_FROM=""             # e.g. "Repurpose <hello@yourdomain.com>"

# Google sign-in (optional) — https://console.cloud.google.com/apis/credentials
# Redirect URI: <NEXT_PUBLIC_APP_URL>/api/auth/google/callback
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Comma-separated emails allowed to view the /admin funnel dashboard
ADMIN_EMAILS=""

# Public URL of the deployed app (used for Stripe redirect URLs)
NEXT_PUBLIC_APP_URL="http://localhost:3000"
